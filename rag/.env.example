# Example environment variables for RAG Pipeline
# Copy this file to .env and fill in your values

# OpenAI API Key (optional - required for LLM answer generation)
# Get your key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# Alternative: Use Ollama for local LLM (no API key needed)
# Install Ollama from: https://ollama.ai
# Set llm_provider to "ollama" in config files
